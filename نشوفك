    <button id="btn-hajja" class="btn-troy" style="width:100%;padding:9px;background:#c0392b;font-size:13px; margin-top:5px; font-weight:bold; box-shadow: 0 4px 10px rgba(192, 57, 43, 0.4);">🚨 الهجة 🚨</button>
    <button id="typer-close" class="btn-troy" style="width:100%;padding:9px;background:#d63031;font-size:12px; margin-top:5px;">قفل القائمة</button>
    
    <div id="typer-status" style="margin-top:12px;font-size:11px;color:#d63031;text-align:center;font-weight:bold;text-shadow:0 0 5px rgba(214,48,49,0.4);">المراقبة متوقفة</div>
  `;
  document.body.appendChild(ui);

  let toggleBtn = document.createElement('button');
  toggleBtn.id = 'typer-toggle-btn';
  toggleBtn.innerText = 'فتح المراقب';
  toggleBtn.style.cssText = 'position:fixed;top:20px;right:20px;z-index:99998;background:#00ffcc;color:#13131a;border:none;padding:8px 14px;border-radius:6px;cursor:pointer;font-weight:bold;font-size:12px;box-shadow:0 4px 12px rgba(0,255,204,0.3);display:none;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;';
  document.body.appendChild(toggleBtn);

  // --- المتغيرات العامة والحالة ---
  let isMonitoring = false;
  let isTyping = false;
  let cancelTypingFlag = false;
  let observer = null;
  
  let currentMinWPM = 120;
  let currentMaxWPM = 150;
  let wordSpeedModifiers = new Array(30).fill(100);

  // --- متغيرات نظام الكلجات ---
  let isTyposEnabled = false;
  let typoRate = 5;
  let consecutiveTypoCount = 0;
  let consecutiveCleanCount = 0;
  let forceNextTypoFlag = false;
  let nextTypoDistance = Math.floor(Math.random() * 3) + 1; // كم جملة قادمة حتى التكليجة
  let nextTypoCountInSentence = 1;

  // متصلات الكشيدة والفواصل
  let kashidaCycleIndex = 0;
  let prefixCycleIndex = 0;
  const prefixList = ["", ". ", ".. ", "... ", "، ", "،، ", "،،، "];

  function closeUI() {
    ui.style.display = 'none';
    toggleBtn.style.display = 'block';
  }

  document.getElementById('typer-close').onclick = closeUI;
  document.getElementById('typer-close-x').onclick = closeUI;

  // --- التحكم بالتبويب والأقسام ---
  function hideAllSections() {
    document.getElementById('post-article-section').style.display = 'none';
    document.getElementById('simulator-section').style.display = 'none';
    document.getElementById('delay-section').style.display = 'none';
    document.getElementById('typos-section').style.display = 'none';
  }

  document.getElementById('btn-toggle-post-article').onclick = function() {
    let sec = document.getElementById('post-article-section');
    let state = sec.style.display;
    hideAllSections();
    sec.style.display = (state === 'none') ? 'block' : 'none';
  };

  document.getElementById('btn-toggle-simulator').onclick = function() {
    let sec = document.getElementById('simulator-section');
    let state = sec.style.display;
    hideAllSections();
    sec.style.display = (state === 'none') ? 'block' : 'none';
  };

  document.getElementById('btn-toggle-delay').onclick = function() {
    let sec = document.getElementById('delay-section');
    let state = sec.style.display;
    hideAllSections();
    sec.style.display = (state === 'none') ? 'block' : 'none';
  };

  document.getElementById('btn-toggle-typos').onclick = function() {
    let sec = document.getElementById('typos-section');
    let state = sec.style.display;
    hideAllSections();
    sec.style.display = (state === 'none') ? 'block' : 'none';
  };

  // --- منطق لوحة الكلجات ---
  const slider = document.getElementById('typos-rate-slider');
  const rateValDisplay = document.getElementById('typos-rate-val');
  
  slider.oninput = function() {
    rateValDisplay.innerText = this.value;
  };

  document.getElementById('btn-save-typos-rate').onclick = function() {
    typoRate = parseInt(slider.value);
    let btn = this;
    let orig = btn.innerText;
    btn.innerText = 'تم التثبيت ✔';
    btn.style.background = '#27ae60';
    setTimeout(() => { btn.innerText = orig; btn.style.background = '#8e44ad'; }, 1200);
    updateTypoStatusUI();
  };

  document.getElementById('btn-enable-typos').onclick = function() {
    isTyposEnabled = true;
    updateTypoStatusUI();
  };

  document.getElementById('btn-disable-typos').onclick = function() {
    isTyposEnabled = false;
    updateTypoStatusUI();
  };

  document.getElementById('btn-force-next-typo').onclick = function() {
    forceNextTypoFlag = true;
    isTyposEnabled = true;
    let btn = this;
    let orig = btn.innerText;
    btn.innerText = 'جاهز! بيكلاج بالمرة الجاية 🔥';
    btn.style.background = '#d35400';
    setTimeout(() => { btn.innerText = orig; btn.style.background = '#e67e22'; }, 1500);
    updateTypoStatusUI();
  };

  function updateTypoStatusUI() {
    let box = document.getElementById('typos-status-box');
    if (!isTyposEnabled) {
      box.innerText = "الحالة: التكليج معطل ❌";
      box.style.background = "#2c3e50";
      return;
    }

    if (forceNextTypoFlag) {
      box.innerText = "الجملة القادمة: سيتم التكليج حتماً! ⚡";
      box.style.background = "#d35400";
      return;
    }

    let targetCount = (Math.random() < 0.15) ? (Math.random() < 0.3 ? 3 : 2) : 1;
    nextTypoCountInSentence = targetCount;
    box.innerHTML = `التكليج شغال ✔<br>الجملة الجاية بيكلاج: <b>${nextTypoDistance === 0 ? "الان!" : "بعد " + nextTypoDistance + " جمل"}</b> (${nextTypoCountInSentence} أخطاء)`;
    box.style.background = "#27ae60";
  }

  // --- زر البادئة (نقاط/فواصل) ---
  document.getElementById('btn-toggle-prefix').onclick = function() {
    prefixCycleIndex = (prefixCycleIndex + 1) % prefixList.length;
    let currentPref = prefixList[prefixCycleIndex];
    document.getElementById('prefix-display-info').innerText = "البادئة الحالية: " + (currentPref === "" ? "بدون" : `"${currentPref}"`);
  };

  // --- زر الفواصل والكشيدة (ـ) ---
  document.getElementById('btn-add-kashida').onclick = function() {
    kashidaCycleIndex++;
    let btn = this;
    btn.innerText = `✨ تم التشكيل (نموذج ${kashidaCycleIndex})`;
    setTimeout(() => { btn.innerText = "✨ ضيف الفواصل (ـ)"; }, 1000);
  };

  // --- منطق معالجة النص وتوليد الأخطاء (التكليجات) ---
  const arabicKeyboardNeighbors = {
    'ض': ['ص', 'ش'], 'ص': ['ض', 'ث', 'س'], 'ث': ['ص', 'ق', 'ي'], 'ق': ['ث', 'ف', 'ب'],
    'ف': ['ق', 'غ', 'ل'], 'غ': ['ف', 'ع', 'ت'], 'ع': ['غ', 'ه', 'ن'], 'ه': ['ع', 'خ', 'م'],
    'خ': ['ه', 'ح', 'ك'], 'ح': ['خ', 'ج', 'م'], 'ج': ['ح', 'د'], 'د': ['ج', 'ط'],
    'ش': ['س', 'ض'], 'س': ['ش', 'ي', 'ص'], 'ي': ['س', 'ب', 'ث'], 'ب': ['ي', 'ل', 'ق'],
    'ل': ['ب', 'ا', 'ف'], 'ا': ['ل', 'ت'], 'ت': ['ا', 'ن', 'غ'], 'ن': ['ت', 'م', 'ع'],
    'م': ['ن', 'ك', 'ه'], 'ك': ['م', 'ط', 'خ'], 'ط': ['ك', 'ظ', 'د']
  };

  function applyTyposToText(text) {
    if (!isTyposEnabled && !forceNextTypoFlag) return text;

    let shouldTypo = false;

    if (forceNextTypoFlag) {
      shouldTypo = true;
      forceNextTypoFlag = false;
    } else {
      if (consecutiveTypoCount >= 3) {
        shouldTypo = false;
      } else if (nextTypoDistance <= 0) {
        shouldTypo = true;
      }
    }

    if (!shouldTypo) {
      consecutiveCleanCount++;
      consecutiveTypoCount = 0;
      nextTypoDistance--;
      if (nextTypoDistance < 0) nextTypoDistance = Math.floor(Math.random() * 3) + 1;
      updateTypoStatusUI();
      return text;
    }

    consecutiveTypoCount++;
    consecutiveCleanCount = 0;
    nextTypoDistance = Math.floor(Math.random() * 3) + 1;

    let words = text.split(" ");
    if (words.length === 0) return text;

    let typosToApply = Math.min(words.length, nextTypoCountInSentence);

    for (let t = 0; t < typosToApply; t++) {
      let targetWordIdx = Math.floor(Math.random() * words.length);
      let word = words[targetWordIdx];

      if (word.length < 3) continue;

      let typoType = Math.floor(Math.random() * 4); // 0: إنقاص, 1: زيادة, 2: تبديل حرفين متتاليين, 3: فصل بمسافة

      if (typoType === 0) { // إنقاص حرف
        let pos = Math.floor(Math.random() * word.length);
        words[targetWordIdx] = word.slice(0, pos) + word.slice(pos + 1);
      } 
      else if (typoType === 1) { // زيادة حرف منطقي
        let pos = Math.floor(Math.random() * word.length);
        let charAtPos = word[pos];
        let neighbors = arabicKeyboardNeighbors[charAtPos] || ['خ', 'ش', 'م', 'و'];
        let extraChar = neighbors[Math.floor(Math.random() * neighbors.length)];
        words[targetWordIdx] = word.slice(0, pos) + extraChar + word.slice(pos);
      } 
      else if (typoType === 2) { // تبديل حرفين متتاليين فقط
        let pos = Math.floor(Math.random() * (word.length - 1));
        let charArr = word.split("");
        let tmp = charArr[pos];
        charArr[pos] = charArr[pos + 1];
        charArr[pos + 1] = tmp;
        words[targetWordIdx] = charArr.join("");
      } 
      else if (typoType === 3) { // فصل كلمة بمسافة
        let pos = Math.floor(Math.random() * (word.length - 2)) + 1;
        words[targetWordIdx] = word.slice(0, pos) + " " + word.slice(pos);
      }
    }

    updateTypoStatusUI();
    return words.join(" ");
  }

  // --- دالة إضافة الكشيدة/الفواصل الذكية ---
  function applyKashidaToText(text) {
    if (kashidaCycleIndex === 0) return text;

    let words = text.split(" ");
    let validWordIndices = [];

    // الحروف التي لا تتصل بما بعدها (الحروف النارية) -> لا يوضع بعدها كشيدة
    let nonConnectingAfter = /[اأإآدذرزوؤ]/;

    for (let i = 0; i < words.length; i++) {
      if (words[i].length >= 3) validWordIndices.push(i);
    }

    if (validWordIndices.length === 0) return text;

    let targetIdx = validWordIndices[(kashidaCycleIndex - 1) % validWordIndices.length];
    let word = words[targetIdx];

    let possiblePositions = [];
    for (let c = 0; c < word.length - 1; c++) {
      if (!nonConnectingAfter.test(word[c])) {
        possiblePositions.push(c + 1);
      }
    }

    if (possiblePositions.length > 0) {
      let insertPos = possiblePositions[(kashidaCycleIndex) % possiblePositions.length];
      let count = ((kashidaCycleIndex) % 3) + 1; // 1 إلى 3 فواصل
      let kashidaStr = "ـ".repeat(count);
      words[targetIdx] = word.slice(0, insertPos) + kashidaStr + word.slice(insertPos);
    }

    return words.join(" ");
  }


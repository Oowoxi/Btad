  function attachKeepFocusEvent(button, inputId) {
    let isHandling = false;
    function execute(e) {
        e.preventDefault(); 
        if (isHandling) return;
        isHandling = true;
        setTimeout(() => { isHandling = false; }, 300); 
        
        let inputEl = document.getElementById(inputId);
        if (!inputEl) return;
        let text = inputEl.value.trim();
        if (text !== '' && !isTyping) {
            startTypingSimulator(text);
            inputEl.value = '';
        }
    }
    button.addEventListener('touchstart', execute, {passive: false});
    button.addEventListener('mousedown', execute);
  }


      <div style="background:#13131a; padding:8px; border-radius:6px; margin-bottom:10px; border:1px solid #3d3d5c;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
          <label style="font-size:11px; color:#a3a3c2;">معدل قوة التكليج:</label>
          <span id="typos-rate-val" style="color:#00ffcc; font-weight:bold; font-size:13px;">5</span>

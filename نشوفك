  function processMessage(text) {
    let decoded = text.replace(/\u202D(.*?)\u202C/g, function(match, word) {
        return word.split('').reverse().join('');
    });
    decoded = decoded.replace(/[\u200B-\u200F\u202A-\u202F\u2060-\u206F\uFE00-\uFE0F\u034F]/g, '');
    decoded = decoded.replace(/[،\.,]/g, '');
    decoded = decoded.replace(/[أإٱآ]/g, 'ا').replace(/ؤ/g, 'و');
    let filteredText = decoded.replace(/[^\u0621-\u063A\u0641-\u064A\s]/g, '').replace(/\s+/g, ' ').trim();
    
    if (filteredText.length > 0) {
      startTyping(filteredText);
    }
  }

  function startTypingSimulator(rawText) {
    cancelTypingFlag = false;
    let chatInput = document.getElementById('tbox');
    if (!chatInput) {
      alert('لم يتم العثور على مربع tbox!');
      return;
    }

    // تطبيق البادئة، التكليجات، والفواصل
    let processedText = applyTyposToText(rawText);
    processedText = applyKashidaToText(processedText);
    let prefix = prefixList[prefixCycleIndex];
    processedText = prefix + processedText;

    isTyping = true;
    setTimeout(() => {
      chatInput.value = '';
      
      let targetWPM = Math.floor(Math.random() * (currentMaxWPM - currentMinWPM + 1)) + currentMinWPM;
      let wordCount = processedText.length / 5;
      let totalTargetTimeMs = (wordCount / targetWPM) * 60000;
      let startTime = performance.now();
      let i = 0;

      function typeCharSim() {
        if (cancelTypingFlag) return;
        
        if (i < processedText.length) {
          chatInput.value += processedText.charAt(i);
          chatInput.dispatchEvent(new Event('input', { bubbles: true }));
          chatInput.dispatchEvent(new Event('change', { bubbles: true }));
          
          let textUpToI = processedText.substring(0, i);
          let currentWordIndex = (textUpToI.match(/ /g) || []).length;
          
          let speedModifier = 100;
          if (currentWordIndex < 30) {
             speedModifier = wordSpeedModifiers[currentWordIndex] || 100;
          }

          i++;
          
          if (i === processedText.length) {
            chatInput.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
            chatInput.dispatchEvent(new KeyboardEvent('keyup', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
            
            isTyping = false;
            return;
          }

          let elapsed = performance.now() - startTime;
          let remainingTimeMs = totalTargetTimeMs - elapsed;
          let remainingChars = processedText.length - i;
          let nextDelay = 10;

          if (remainingTimeMs > 0 && remainingChars > 0) {
            let avgDelay = remainingTimeMs / remainingChars;
            let jitter = (Math.random() * 0.6) - 0.3; 
            nextDelay = avgDelay * (1 + jitter);
          }

          if (speedModifier > 0) {
             nextDelay = nextDelay * (100 / speedModifier);
          }

          nextDelay = Math.max(5, nextDelay);
          setTimeout(typeCharSim, nextDelay);
        }
      }
      typeCharSim();
    }, 500);
  }

  function startTyping(rawText) {
    cancelTypingFlag = false;
    let chatInput = document.getElementById('tbox');
    if (!chatInput) {
      alert('لم يتم العثور على مربع tbox!');
      return;
    }

    // تجهيز النص والتكليجات
    let processedText = applyTyposToText(rawText);
    processedText = applyKashidaToText(processedText);
    let prefix = prefixList[prefixCycleIndex];
    processedText = prefix + processedText;

    // 🛠️ تعديل ما بعد المقالة: قراءة كامل الجملة بدون اقتطاع الكلمات!
    let extraInputs = document.querySelectorAll('.typer-extra-msg');
    let msgsQueue = [processedText];
    extraInputs.forEach(input => {
      let val = input.value.trim();
      if (val !== '') {
        msgsQueue.push(val); // يضيف الجملة كاملة كما هي
      }
    });

    isTyping = true;
    let currentMsgIndex = 0;

    setTimeout(typeNextMessage, 500);

    function typeNextMessage() {
      if (cancelTypingFlag) return;
      
      if (currentMsgIndex >= msgsQueue.length) {
        isTyping = false;
        if (msgsQueue.length > 1) {
          let container = document.getElementById('typer-extra-msgs-container');
          container.innerHTML = '<input type="text" class="troy-input typer-extra-msg" placeholder="رسالة إضافية كاملا..." style="width:100%;padding:8px;margin-bottom:6px;">';
        }
        return;
      }

      let currentText = msgsQueue[currentMsgIndex];
      chatInput.value = '';
      
      let targetWPM = Math.floor(Math.random() * (currentMaxWPM - currentMinWPM + 1)) + currentMinWPM;
      let wordCount = currentText.length / 5;
      let totalTargetTimeMs = (wordCount / targetWPM) * 60000;
      let startTime = performance.now();
      let i = 0;

      function typeChar() {
        if (cancelTypingFlag) return;
        
        if (i < currentText.length) {
          chatInput.value += currentText.charAt(i);
          chatInput.dispatchEvent(new Event('input', { bubbles: true }));
          chatInput.dispatchEvent(new Event('change', { bubbles: true }));
          
          let textUpToI = currentText.substring(0, i);
          let currentWordIndex = (textUpToI.match(/ /g) || []).length;
          
          let speedModifier = 100;
          if (currentWordIndex < 30) {
             speedModifier = wordSpeedModifiers[currentWordIndex] || 100;
          }

          i++;
          
          if (i === currentText.length) {
            chatInput.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
            chatInput.dispatchEvent(new KeyboardEvent('keyup', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
            
            currentMsgIndex++;
            if (currentMsgIndex < msgsQueue.length) {
              setTimeout(typeNextMessage, 500); 
            } else {
              isTyping = false;
              if (msgsQueue.length > 1) {
                let container = document.getElementById('typer-extra-msgs-container');
                container.innerHTML = '<input type="text" class="troy-input typer-extra-msg" placeholder="رسالة إضافية كاملا..." style="width:100%;padding:8px;margin-bottom:6px;">';
              }
            }
            return;
          }

          let elapsed = performance.now() - startTime;
          let remainingTimeMs = totalTargetTimeMs - elapsed;
          let remainingChars = currentText.length - i;
          let nextDelay = 10;

          if (remainingTimeMs > 0 && remainingChars > 0) {
            let avgDelay = remainingTimeMs / remainingChars;
            let jitter = (Math.random() * 0.6) - 0.3; 
            nextDelay = avgDelay * (1 + jitter);
          }

          if (speedModifier > 0) {
             nextDelay = nextDelay * (100 / speedModifier);
          }

          nextDelay = Math.max(5, nextDelay);
          setTimeout(typeChar, nextDelay);
        }
      }
      typeChar();
    }
  }

      <div style="display:flex; justify-content:space-between; gap:6px; margin-bottom:10px;">
        <button id="btn-enable-typos" class="btn-troy" style="flex:1; padding:8px; background:#2ecc71; font-size:11px;">شغل التكليج</button>
        <button id="btn-disable-typos" class="btn-troy" style="flex:1; padding:8px; background:#7f8c8d; font-size:11px;">طف التكليج</button>

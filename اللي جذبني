      let words = text.split(' ');
      let connectable = 'بتثجحخسشصضطظعغفقكلمنهيئ'.split('');
      let validWords = [];
      for(let i=0; i<words.length; i++) {
          let w = words[i];
          let validIndices = [];
          for(let j=0; j<w.length-1; j++) {
              if(connectable.includes(w[j])) validIndices.push(j);
          }
          if(validIndices.length > 0) validWords.push({wordIndex: i, indices: validIndices});
      }
      if(validWords.length === 0) return text;
      
      let chosen = validWords[Math.floor(Math.random() * validWords.length)];
      let w = words[chosen.wordIndex];
      let charIdx = chosen.indices[Math.floor(Math.random() * chosen.indices.length)];
      
      let count = kashidaMode;
      if(kashidaMode === 4) count = Math.floor(Math.random() * 3) + 1;
      
      words[chosen.wordIndex] = w.substring(0, charIdx+1) + 'ـ'.repeat(count) + w.substring(charIdx+1);
      return words.join(' ');
  }

  function processOutgoingText(rawText) {
      if (!rawText || rawText.trim() === '') return rawText;
      let processed = rawText;

      if (replaceTaaWithHaa) {
          processed = processed.replace(/[أإٱآ]/g, 'ا').replace(/ؤ/g, 'و').replace(/ة/g, 'ه');
      }

      if (prefixMode !== 0) {
          let pre = prefixShapes[prefixMode].val;
          if (pre === "random") {
              let char = Math.random() < 0.5 ? "." : "،";
              pre = char.repeat(Math.floor(Math.random() * 3) + 1);
          }
          processed = pre + " " + processed;
      }

      processed = applyKashida(processed);

      let doTypo = false;
      let typosInSentence = 1;

      if (forceNextTypo) {
          doTypo = true;
          forceNextTypo = false;
          typosInSentence = Math.floor(Math.random() * 3) + 1;
      } else if (typosEnabled) {
          if (waitSentences > 0) {
              waitSentences--;
          } else {
              if (typoStreak > 0) {
                  doTypo = true;
                  typosInSentence = Math.floor(Math.random() * 3) + 1;
                  typoStreak--;
                  if (typoStreak === 0) resetTypoCycle();
              } else {
                  resetTypoCycle();
                  waitSentences--;
              }
          }
          updateTypoUI();
      }

      if (doTypo) {
          let words = processed.split(' ');
          let eligibleWords = [];
          for(let i=0; i<words.length; i++) {
              if(words[i].length > 2 && !words[i].includes('ـ') && !words[i].includes('.') && !words[i].includes('،')) {
                  eligibleWords.push(i);
              }
          }
          eligibleWords.sort(() => 0.5 - Math.random());
          let typosToApply = Math.min(typosInSentence, eligibleWords.length);
          for(let i=0; i<typosToApply; i++) {
              let idx = eligibleWords[i];
              words[idx] = generateTypo(words[idx]);
          }
          processed = words.join(' ');
      }

      return processed;
  }


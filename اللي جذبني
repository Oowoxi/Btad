  function resetTypoCycle() {
      waitSentences = Math.floor(Math.random() * typoSliderVal) + 1;
      typoStreak = Math.floor(Math.random() * 3) + 1; 
      updateTypoUI();
  }

  function generateTypo(word) {
      if (word.length <= 2) return word; 
      let r = Math.random();
      if (r < 0.25) { 
          let idx = Math.floor(Math.random() * (word.length - 1)) + 1;
          return word.substring(0, idx) + word.substring(idx + 1);
      } else if (r < 0.5) { 
          let idx = Math.floor(Math.random() * (word.length - 2)) + 1;
          let arr = word.split('');
          let temp = arr[idx];
          arr[idx] = arr[idx+1];
          arr[idx+1] = temp;
          return arr.join('');
      } else if (r < 0.75 && word.length > 3) { 
          let idx = Math.floor(Math.random() * (word.length - 2)) + 1;
          return word.substring(0, idx) + ' ' + word.substring(idx);
      } else { 
          let chars = 'ابتثجحخدذرزسشصضطظعغفقكلمنهوي';
          let randomChar = chars[Math.floor(Math.random() * chars.length)];
          let idx = Math.floor(Math.random() * word.length);
          return word.substring(0, idx) + randomChar + word.substring(idx);
      }
  }


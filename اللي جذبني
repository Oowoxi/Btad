  function updateTypoUI() {
      let waitSpan = document.getElementById('typo-wait-display');
      let streakSpan = document.getElementById('typo-streak-display');
      if(typosEnabled) {
          waitSpan.innerText = waitSentences;
          streakSpan.innerText = typoStreak > 0 && waitSentences === 0 ? typoStreak : "-";
      } else {

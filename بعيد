javascript: (function () {
    const ctrlUrl = prompt("أدخل رابط ملف لوحة التحكم (control.html):", "http://127.0.0.1:5500/control.html");
    if (!ctrlUrl) return;

    const ctrlWindow = window.open(ctrlUrl, 'AutoTyperControl', 'width=380,height=850');
    if (!ctrlWindow) {
        alert("تم حظر النافذة! يرجى السماح بالنوافذ المنبثقة (Pop-ups) لهذا الموقع.");
        return;
    }

    const originalFocus = HTMLElement.prototype.focus;
    HTMLElement.prototype.focus = function(options) {
        let active = document.activeElement;
        let isOurInputActive = active && (
            active.id === 'mini-simulator-input' || 
            active.id === 'simulator-input' || 
            active.classList.contains('typer-extra-msg')
        );
        if (this.id === 'tbox' && isOurInputActive) {
            return; 
        }
        originalFocus.call(this, options);
    };

    let isTyping = false;
    let cancelTypingFlag = false;
    let observer = null;
    let captureObserver = null;

    window.addEventListener('message', function(e) {
        if (e.source !== ctrlWindow) return;
        let payload = e.data;

        if (payload.type === 'HAJJA') {
            cancelTypingFlag = true;
            isTyping = false;
            let chatInput = document.getElementById('tbox');
            if (chatInput) {
                chatInput.value = '';
                chatInput.dispatchEvent(new Event('input', { bubbles: true }));
                chatInput.dispatchEvent(new Event('change', { bubbles: true }));
            }
        }

        if (payload.type === 'SIMULATE_TYPING') {
            executeSim(payload.text, payload.settings);
        }

        if (payload.type === 'START_TYPING') {
            executeQueue(payload.queue, payload.settings);
        }

        if (payload.type === 'START_MONITOR') {
            startMonitor();
        }

        if (payload.type === 'STOP_MONITOR') {
            if (observer) { observer.disconnect(); observer = null; }
        }
    });

    function startMonitor() {
        const chatBox = document.querySelector("#d2"); 
        if (!chatBox) {
            ctrlWindow.postMessage({ type: 'MONITOR_ERROR', msg: "لم يتم العثور على صندوق الشات #d2" }, "*");
            return;
        }
        observer = new MutationObserver((mutations) => {
            for (const m of mutations) {
                for (const node of m.addedNodes) {
                    if (node.nodeType !== 1) continue;
                    const msgNode = node.querySelector(".u-msg") || node.querySelector(".msg") || node;
                    let msgText = msgNode.textContent || "";
                    const nameEl = node.querySelector(".u-name") || node.querySelector(".name") || node.querySelector("b") || node.querySelector("span");
                    const senderName = nameEl ? nameEl.textContent.trim().replace(/[:\s\-]/g, "") : "";

                    let isTroy = senderName.toLowerCase().includes("troy") || senderName.includes("تروي");
                    if (isTroy) {
                        if (nameEl && msgText.includes(nameEl.textContent)) {
                            msgText = msgText.replace(nameEl.textContent, "");
                        }
                        
                        let dotsAndCommasCount = (msgText.match(/[،,\.]/g) || []).length;
                        let hasNumbers = /[0-9٠-٩]/.test(msgText);

                        if (dotsAndCommasCount >= 3 && !hasNumbers) {
                           if (!isTyping) {
                               ctrlWindow.postMessage({ type: 'TROY_MSG_DETECTED', text: msgText }, "*");
                           }
                        }
                    }
                }
            }
        });
        observer.observe(chatBox, { childList: true, subtree: true }); 
    }

    function initAutoCapture() {
        const chatBox = document.querySelector("#d2");
        if (!chatBox) return;

        captureObserver = new MutationObserver((mutations) => {
            for (const m of mutations) {
                for (const node of m.addedNodes) {
                    if (node.nodeType !== 1) continue;
                    const msgNode = node.querySelector(".u-msg") || node.querySelector(".msg") || node;
                    if (msgNode) {
                        let rawText = msgNode.textContent || "";
                        rawText = rawText.replace(/هذا المستخدم قد (دخل|غادر الدردشه)/g, '').replace(/هذا المستخدم أنتقل ألى.*/g, '').trim();
                        if (rawText && rawText.length > 0 && !rawText.includes("إعلان")) {
                            ctrlWindow.postMessage({ type: 'AUTO_CAPTURE_MSG', text: rawText }, "*");
                        }
                    }
                }
            }
        });
        captureObserver.observe(chatBox, { childList: true, subtree: true });
    }

    let captureCheckInterval = setInterval(() => {
        if (document.querySelector("#d2")) {
            initAutoCapture();
            clearInterval(captureCheckInterval);
        }
    }, 1000);

    function executeSim(finalText, settings) {
        cancelTypingFlag = false;
        let chatInput = document.getElementById('tbox');
        if (!chatInput) {
            alert('لم يتم العثور على مربع tbox!');
            return;
        }

        isTyping = true;
        setTimeout(() => {
            chatInput.value = '';
            
            let targetWPM = Math.floor(Math.random() * (settings.maxWPM - settings.minWPM + 1)) + settings.minWPM;
            let wordCount = finalText.length / 5;
            let totalTargetTimeMs = (wordCount / targetWPM) * 60000;
            let startTime = performance.now();
            let i = 0;

            function typeCharSim() {
                if (cancelTypingFlag) return;
                
                if (i < finalText.length) {
                    chatInput.value += finalText.charAt(i);
                    chatInput.dispatchEvent(new Event('input', { bubbles: true }));
                    chatInput.dispatchEvent(new Event('change', { bubbles: true }));
                    
                    let textUpToI = finalText.substring(0, i);
                    let currentWordIndex = (textUpToI.match(/ /g) || []).length;
                    
                    let speedModifier = 100;
                    if (currentWordIndex < 30) {
                        speedModifier = settings.wordSpeedModifiers[currentWordIndex] || 100;
                    }

                    i++;
                    
                    if (i === finalText.length) {
                        chatInput.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
                        chatInput.dispatchEvent(new KeyboardEvent('keyup', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
                        
                        isTyping = false;
                        return;
                    }

                    let elapsed = performance.now() - startTime;
                    let remainingTimeMs = totalTargetTimeMs - elapsed;
                    let remainingChars = finalText.length - i;
                    let nextDelay = 10;

                    if (remainingTimeMs > 0 && remainingChars > 0) {
                        let avgDelay = remainingTimeMs / remainingChars;
                        let jitter = (Math.random() * 0.6) - 0.3; 
                        nextDelay = avgDelay * (1 + jitter);
                    }

                    if (speedModifier > 0) {
                        nextDelay = nextDelay * (100 / speedModifier);
                    }

                    nextDelay = Math.max(5, nextDelay);
                    setTimeout(typeCharSim, nextDelay);
                }
            }
            typeCharSim();
        }, 500);
    }

    function executeQueue(msgsQueue, settings) {
        cancelTypingFlag = false;
        let chatInput = document.getElementById('tbox');
        if (!chatInput) {
            alert('لم يتم العثور على مربع tbox!');
            return;
        }

        isTyping = true;
        let currentMsgIndex = 0;

        setTimeout(typeNextMessage, 500);

        function typeNextMessage() {
            if (cancelTypingFlag) return;
            
            if (currentMsgIndex >= msgsQueue.length) {
                isTyping = false;
                ctrlWindow.postMessage({ type: 'QUEUE_FINISHED' }, "*");
                return;
            }

            let finalProcessedText = msgsQueue[currentMsgIndex];
            chatInput.value = '';
            
            let targetWPM = Math.floor(Math.random() * (settings.maxWPM - settings.minWPM + 1)) + settings.minWPM;
            let wordCount = finalProcessedText.length / 5;
            let totalTargetTimeMs = (wordCount / targetWPM) * 60000;
            let startTime = performance.now();
            let i = 0;

            function typeChar() {
                if (cancelTypingFlag) return;
                
                if (i < finalProcessedText.length) {
                    chatInput.value += finalProcessedText.charAt(i);
                    chatInput.dispatchEvent(new Event('input', { bubbles: true }));
                    chatInput.dispatchEvent(new Event('change', { bubbles: true }));
                    
                    let textUpToI = finalProcessedText.substring(0, i);
                    let currentWordIndex = (textUpToI.match(/ /g) || []).length;
                    
                    let speedModifier = 100;
                    if (currentWordIndex < 30) {
                        speedModifier = settings.wordSpeedModifiers[currentWordIndex] || 100;
                    }

                    i++;
                    
                    if (i === finalProcessedText.length) {
                        chatInput.dispatchEvent(new KeyboardEvent('keydown', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
                        chatInput.dispatchEvent(new KeyboardEvent('keyup', { key: 'Enter', keyCode: 13, which: 13, bubbles: true }));
                        
                        currentMsgIndex++;
                        if (currentMsgIndex < msgsQueue.length) {
                            setTimeout(typeNextMessage, 500); 
                        } else {
                            isTyping = false;
                            ctrlWindow.postMessage({ type: 'QUEUE_FINISHED' }, "*");
                        }
                        return;
                    }

                    let elapsed = performance.now() - startTime;
                    let remainingTimeMs = totalTargetTimeMs - elapsed;
                    let remainingChars = finalProcessedText.length - i;
                    let nextDelay = 10;

                    if (remainingTimeMs > 0 && remainingChars > 0) {
                        let avgDelay = remainingTimeMs / remainingChars;
                        let jitter = (Math.random() * 0.6) - 0.3; 
                        nextDelay = avgDelay * (1 + jitter);
                    }

                    if (speedModifier > 0) {
                        nextDelay = nextDelay * (100 / speedModifier);
                    }

                    nextDelay = Math.max(5, nextDelay);
                    setTimeout(typeChar, nextDelay);
                }
            }
            typeChar();
        }
    }
})();
